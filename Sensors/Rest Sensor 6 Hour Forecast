template:
  - trigger:
      - platform: time_pattern
        hours: "/1"
      - platform: homeassistant
        event: start
    action:
      - service: weather.get_forecasts
        target:
          entity_id: weather.forecast_home
        data:
          type: hourly
        response_variable: forecast_hourly
    sensor:
      - name: "Weather Forecast Hourly 0"
        state: "{{ forecast_hourly['weather.forecast_home'].forecast[0].condition }}"
        attributes:
          datetime: "{{ forecast_hourly['weather.forecast_home'].forecast[0].datetime }}"
          temperature: "{{ forecast_hourly['weather.forecast_home'].forecast[0].temperature }}"
          precipitation: "{{ forecast_hourly['weather.forecast_home'].forecast[0].precipitation }}"
          precipitation_probability: "{{ forecast_hourly['weather.forecast_home'].forecast[0].precipitation_probability }}"
          wind_speed: "{{ forecast_hourly['weather.forecast_home'].forecast[0].wind_speed }}"
          wind_bearing: "{{ forecast_hourly['weather.forecast_home'].forecast[0].wind_bearing }}"
          time: "{{ as_datetime(forecast_hourly['weather.forecast_home'].forecast[0].datetime).strftime('%H:%M') }}"
